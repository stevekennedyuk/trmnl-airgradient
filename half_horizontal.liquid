{% comment %} AirGradient – Half Horizontal (left panel) {% endcomment %}
{% assign reading = data[0] %}

{% assign pm25 = reading.pm02 | plus: 0 %}
{% if pm25 <= 12.0 %}{% assign aqi_cat = "GOOD" %}{% assign aqi_lo = 0 %}{% assign aqi_hi = 50 %}{% assign pm_lo = 0.0 %}{% assign pm_hi = 12.0 %}
{% elsif pm25 <= 35.4 %}{% assign aqi_cat = "MODERATE" %}{% assign aqi_lo = 51 %}{% assign aqi_hi = 100 %}{% assign pm_lo = 12.1 %}{% assign pm_hi = 35.4 %}
{% elsif pm25 <= 55.4 %}{% assign aqi_cat = "UNHEALTHY*" %}{% assign aqi_lo = 101 %}{% assign aqi_hi = 150 %}{% assign pm_lo = 35.5 %}{% assign pm_hi = 55.4 %}
{% else %}{% assign aqi_cat = "UNHEALTHY" %}{% assign aqi_lo = 151 %}{% assign aqi_hi = 200 %}{% assign pm_lo = 55.5 %}{% assign pm_hi = 150.4 %}{% endif %}
{% assign aqi_val = pm25 | minus: pm_lo | times: aqi_hi | minus: aqi_lo | divided_by: pm_hi | minus: pm_lo | plus: aqi_lo | round %}

{% assign loc_label = trmnl.plugin_settings.custom_fields_values.location_name | default: "Air Quality" %}

<style>
  *,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
  .hh{width:100%;height:100%;display:flex;flex-direction:column;font-family:"Courier New",monospace;background:#fff;color:#000}
  .hh-top{background:#000;color:#fff;padding:8px 12px;display:flex;align-items:center;gap:12px;flex-shrink:0}
  .hh-top .aqi-num{font-size:44px;font-weight:bold;line-height:1}
  .hh-top .aqi-info{display:flex;flex-direction:column;gap:2px}
  .hh-top .aqi-lbl{font-size:8px;letter-spacing:2px;text-transform:uppercase;opacity:.65}
  .hh-top .aqi-cat{font-size:10px;font-weight:bold;letter-spacing:1px;border:1.5px solid #fff;padding:2px 6px;text-transform:uppercase;display:inline-block}
  .hh-grid{flex:1;display:grid;grid-template-columns:1fr 1fr;grid-template-rows:repeat(3,1fr)}
  .hh-cell{padding:6px 10px;border-right:1px solid #ccc;border-bottom:1px solid #ccc;display:flex;flex-direction:column;justify-content:space-between}
  .hh-cell:nth-child(2n){border-right:none}
  .hh-cell:nth-child(n+5){border-bottom:none}
  .lbl{font-size:7px;letter-spacing:1.5px;text-transform:uppercase;opacity:.5}
  .val{font-size:26px;font-weight:bold;line-height:1}
  .unt{font-size:8px;opacity:.4}
  .bar{width:100%;height:2px;background:#eee;margin-top:3px;border-radius:1px;overflow:hidden}
  .bar-f{height:100%;background:#000;border-radius:1px}
</style>

<div class="hh">
  <div class="hh-top">
    <div class="aqi-num">{{ aqi_val }}</div>
    <div class="aqi-info">
      <div class="aqi-lbl">US AQI</div>
      <div class="aqi-cat">{{ aqi_cat }}</div>
    </div>
  </div>
  <div class="hh-grid">
    <div class="hh-cell">
      <div class="lbl">PM2.5</div>
      <div class="val">{{ reading.pm02 | round: 1 }}</div>
      <div class="unt">µg/m³</div>
      {% assign p = reading.pm02 | times: 100 | divided_by: 150 %}<div class="bar"><div class="bar-f" style="width:{{ p }}%"></div></div>
    </div>
    <div class="hh-cell">
      <div class="lbl">CO₂</div>
      <div class="val">{{ reading.rco2 | round }}</div>
      <div class="unt">ppm</div>
      {% assign p = reading.rco2 | times: 100 | divided_by: 2000 %}<div class="bar"><div class="bar-f" style="width:{{ p }}%"></div></div>
    </div>
    <div class="hh-cell">
      <div class="lbl">Temperature</div>
      <div class="val">{{ reading.atmp | round: 1 }}</div>
      <div class="unt">°C</div>
    </div>
    <div class="hh-cell">
      <div class="lbl">Humidity</div>
      <div class="val">{{ reading.rhum | round }}</div>
      <div class="unt">% RH</div>
      <div class="bar"><div class="bar-f" style="width:{{ reading.rhum }}%"></div></div>
    </div>
    <div class="hh-cell">
      <div class="lbl">TVOC Index</div>
      <div class="val">{{ reading.tvocIndex | round }}</div>
      <div class="unt">/ 500</div>
      {% assign p = reading.tvocIndex | times: 100 | divided_by: 500 %}<div class="bar"><div class="bar-f" style="width:{{ p }}%"></div></div>
    </div>
    <div class="hh-cell">
      <div class="lbl">NOx Index</div>
      <div class="val">{{ reading.noxIndex | round }}</div>
      <div class="unt">/ 500</div>
      {% assign p = reading.noxIndex | times: 100 | divided_by: 500 %}<div class="bar"><div class="bar-f" style="width:{{ p }}%"></div></div>
    </div>
  </div>
</div>

<div class="title_bar">
  <span class="title">{{ loc_label }} · Air Quality</span>
  <span class="instance">AirGradient</span>
</div>
